% \section{Loading the Package}
%
% Write a line in the preamble
% \begin{quote}
%   "\usepackage[color = "\meta{color}"]{fancydoc}"
% \end{quote}
%
% \section{User's Interfaces}
%
% \begin{function}{codedemo}
%   \begin{syntax}
%  |\begin{codedemo}|
%  |  Code needs to be typeset in verbatim and demoed|
%  |\end{codedemo}|
%   \end{syntax}
% Typeset the code on the left hand side and then execute the code and demo in
% the right hand side.
% \end{function}
%
% \begin{function}{\keys}
%   \begin{syntax}
%     \tn{keys} \oarg{options} \marg{comma list}
%   \end{syntax}
%   
% For example,
% \iffalse
%<*example>
% \fi
\begin{codedemo}
  \keys [font = \sl] {keya, keyb, keyc}\\
  \keys [emph = 2, delimiter = \textbar]
        {true, false, not given}
\end{codedemo}
% \iffalse
%</example>
% \fi
% \end{function}
%
% \begin{function}{\TF, \TTF, \TFF}
%   Shortcut for typeset Boolean choices.
% \begin{itemize}
%   \item \tn{TF}| | will output \TF,
%   \item \tn{TTF}   will output \TTF, and
%   \item \tn{TFF}   will output \TFF.
% \end{itemize}
% \end{function}
%
% \end{documentation}
